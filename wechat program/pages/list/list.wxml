                <text class="c-block wx-image_movielist_item_score allstar45" data-c_e_id="wx_text_53bda5e3">{{item.rating}}</text>
                <text class="c-block wx-image_movielist_item_director" data-c_e_id="wx_text_63f36d55">导演:{{item.director}}</text>
                <text class="c-block wx-image_movielist_item_actors" data-c_e_id="wx_text_3b979059">主演:{{item.actor}}</text>
            </view>
        </view>
    </navigator>
