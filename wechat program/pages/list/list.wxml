<input bindinput ="inputfind" class="c-block c-fullwidth wx-input_DldPWb" data-c_e_id="wx_input_27f79b1f" name="input1" placeholder="请输入电影信息                            " type="text"/>
<button class="wx-button_yRWV2B" data-c_e_id="wx_button_03ca732e" hover-class="button-hover" size="mini" type="primary" bindtap ="search">
    搜索
</button>
<scroll-view wx:for="{{ans}}" class="c-minheight wx-scroll-view_6Bnkj2" data-c_e_id="wx_scroll_view_fcc22f86" lower-threshold="50" scroll-y="True" style="overflow-x: hidden; overflow-y: auto; " upper-threshold="50">
    <navigator class="wx-navigator_movielist_item" data-c_e_id="wx_navigator_46b77b4d" hover-class="navigator-hover" url="../detial/detial">
